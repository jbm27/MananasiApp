# --- Local frontend (repo root) ---
# Leave empty in dev — Vite proxies /api to the local server.
# On Vercel, set to your Railway API URL, e.g. https://mananasi-api.up.railway.app
VITE_API_URL=

# --- Local backend (server/.env) ---
# PostgreSQL connection string (Railway sets DATABASE_URL automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/mananasi

# API port for local development
PORT=3001

# Disable SSL for local Postgres (Railway uses SSL by default)
# PGSSLMODE=disable

# Comma-separated browser origins allowed to call the API (required for Vercel + Railway split)
# Example: https://mananasi.vercel.app,https://mananasi-git-main-yourteam.vercel.app
CORS_ORIGIN=http://localhost:5173
